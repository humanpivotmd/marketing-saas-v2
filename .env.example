# ============================================
# MarketingFlow 환경변수 (.env.local에 복사 후 값 설정)
# ============================================

# --- Supabase (필수) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# --- JWT (필수, 32자 이상) ---
JWT_SECRET=your-jwt-secret-minimum-32-characters

# --- AI API 키 (필수, 둘 중 하나 이상) ---
# 코드: process.env.ANTHROPIC_API_KEY || process.env.CLAUDE_API_KEY
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx
CLAUDE_API_KEY=sk-ant-api03-xxxxxxxxxxxx

# --- 암호화 키 (선택, 32자 이상) ---
ENCRYPTION_KEY=your-encryption-key-minimum-32-chars

# --- Resend 이메일 (선택) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
MAIL_FROM=noreply@marketingflow.kr
MAIL_FROM_NAME=MarketingFlow

# --- 네이버 검색광고 API (선택) ---
NAVER_AD_CUSTOMER_ID=
NAVER_AD_ACCESS_KEY=
NAVER_AD_SECRET_KEY=

# --- 네이버 DataLab API (선택) ---
DATALAB_CLIENT_ID=
DATALAB_CLIENT_SECRET=

# --- 토스페이먼츠 (선택) ---
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

# --- 앱 URL ---
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://marketingflow.kr

# --- 환경 ---
NODE_ENV=development
